# ============================================
# CONFIGURACIÓN DE BASE DE DATOS (Supabase)
# ============================================
# Obtén estas credenciales de: https://supabase.com/dashboard
# Project Settings > Database > Connection string
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Supabase Client (para storage y auth)
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[YOUR-ANON-KEY]"

# ============================================
# CONFIGURACIÓN DE WOMPI (Pagos)
# ============================================
# Sandbox (pruebas)
WOMPI_PUBLIC_KEY="pub_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
WOMPI_PRIVATE_KEY="prv_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
WOMPI_API_URL="https://sandbox.wompi.sv"

# Producción (cuando estés listo)
# WOMPI_PUBLIC_KEY="pub_prod_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# WOMPI_PRIVATE_KEY="prv_prod_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# WOMPI_API_URL="https://api.wompi.sv"

# Webhook secret para verificar que los webhooks vienen de Wompi
WOMPI_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ============================================
# CONFIGURACIÓN DE LA APP
# ============================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# NEXT_PUBLIC_APP_URL="https://tudominio.com"

# JWT Secret para autenticación de admin
JWT_SECRET="tu-secreto-super-seguro-minimo-32-caracteres"

