# ============================================
# CONFIGURACIÓN PARA PRODUCCIÓN
# ============================================

# --------------------------------------------
# BASE DE DATOS - SUPABASE (REQUERIDO)
# --------------------------------------------
# 1. Ve a https://supabase.com
# 2. Crea un nuevo proyecto
# 3. Ve a Project Settings > Database
# 4. Copia el "Connection string" (URI)
# 5. Reemplaza [YOUR-PASSWORD] con tu contraseña
DATABASE_URL="postgresql://postgres:TU_PASSWORD@db.TU_REF.supabase.co:5432/postgres"

# --------------------------------------------
# SUPABASE - API KEYS (REQUERIDO)
# --------------------------------------------
# Ve a Project Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://TU_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="TU_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="TU_SERVICE_ROLE_KEY"

# --------------------------------------------
# PAGOS - WOMPI (BAC Credomatic) (OPCIONAL)
# --------------------------------------------
# Para pruebas usa Sandbox: https://sandbox.wompi.sv
# Para producción: https://wompi.sv
WOMPI_PUBLIC_KEY="pub_test_XXXXXXXXXXXXXXXXX"
WOMPI_PRIVATE_KEY="prv_test_XXXXXXXXXXXXXXXXX"
WOMPI_API_URL="https://sandbox.wompi.sv"
WOMPI_WEBHOOK_SECRET="whsec_XXXXXXXXXXXXXXXXX"

# --------------------------------------------
# APP CONFIG (REQUERIDO)
# --------------------------------------------
NEXT_PUBLIC_APP_URL="https://tu-dominio.vercel.app"
JWT_SECRET="minimo-32-caracteres-seguros-muy-largo-para-jwt"

# --------------------------------------------
# MODO DEMO (SOLO PARA DESARROLLO)
# Si esta variable existe, el sistema usa datos locales
