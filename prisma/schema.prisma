generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id            String    @id @default(cuid())
  name          String
  description   String
  price         Decimal   @db.Decimal(10, 2)
  originalPrice Decimal?  @db.Decimal(10, 2)
  image         String
  images        String[]
  category      String
  tags          String[]
  sizes         String[]
  colors        Json
  inStock       Boolean   @default(true)
  isNew         Boolean   @default(false)
  isBestseller  Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  orderItems    OrderItem[]
  
  @@map("products")
}

model Order {
  id            String      @id @default(cuid())
  status        OrderStatus @default(PENDING)
  total         Decimal     @db.Decimal(10, 2)
  shippingCost  Decimal     @default(0) @db.Decimal(10, 2)
  
  customerEmail String
  customerName  String
  customerPhone String
  
  address       String
  city          String
  department    String
  postalCode    String
  
  // Información de envío
  trackingNumber String?    // Número de guía de envío
  carrier        String?    // Transportista (Mensajeria, Cargo Expreso, etc.)
  shippedAt      DateTime?  // Fecha de envío
  deliveredAt    DateTime?  // Fecha de entrega
  
  // Información de pago
  paymentId     String?
  paymentStatus PaymentStatus @default(PENDING)
  paidAt        DateTime?
  
  // Relaciones
  items         OrderItem[]
  trackingHistory OrderTracking[]
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  quantity  Int
  price     Decimal @db.Decimal(10, 2)
  size      String
  color     String
  
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId String
  product   Product @relation(fields: [productId], references: [id])
  
  @@map("order_items")
}

// Historial de tracking de cada orden
model OrderTracking {
  id          String    @id @default(cuid())
  status      OrderStatus
  description String?   // Descripción del evento
  location    String?   // Ubicación (ciudad, centro de distribución)
  
  orderId     String
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  createdBy   String?   // ID del admin que actualizó
  createdAt   DateTime  @default(now())
  
  @@map("order_tracking")
  @@index([orderId])
}

enum OrderStatus {
  PENDING       // Pendiente de pago
  PAID          // Pagado, esperando preparación
  PROCESSING    // Preparando pedido
  READY         // Listo para envío
  SHIPPED       // Enviado
  IN_TRANSIT    // En tránsito
  OUT_FOR_DELIVERY // En reparto
  DELIVERED     // Entregado
  CANCELLED     // Cancelado
  REFUNDED      // Reembolsado
}

enum PaymentStatus {
  PENDING
  PROCESSING
  APPROVED
  DECLINED
  ERROR
  REFUNDED
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  isActive  Boolean  @default(true)
  lastLogin DateTime?
  createdAt DateTime @default(now())
  
  @@map("admins")
}
