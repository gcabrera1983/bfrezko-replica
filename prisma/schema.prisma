generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id            String    @id @default(cuid())
  name          String
  description   String
  price         Decimal   @db.Decimal(10, 2)
  originalPrice Decimal?  @db.Decimal(10, 2) @map("original_price")
  image         String
  images        String[]
  category      String
  tags          String[]
  sizes         String[]
  colors        Json
  inStock       Boolean   @default(true) @map("in_stock")
  isNew         Boolean   @default(false) @map("is_new")
  isBestseller  Boolean   @default(false) @map("is_bestseller")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  
  orderItems    OrderItem[]
  
  @@map("products")
}

model Order {
  id            String      @id @default(cuid())
  status        OrderStatus @default(PENDING)
  total         Decimal     @db.Decimal(10, 2)
  shippingCost  Decimal     @default(0) @db.Decimal(10, 2) @map("shipping_cost")
  
  customerEmail String @map("customer_email")
  customerName  String @map("customer_name")
  customerPhone String @map("customer_phone")
  
  address       String
  city          String
  department    String
  postalCode    String @map("postal_code")
  
  // Información de envío
  trackingNumber String? @map("tracking_number")
  carrier        String?
  shippedAt      DateTime? @map("shipped_at")
  deliveredAt    DateTime? @map("delivered_at")
  
  // Información de pago
  paymentId     String? @map("payment_id")
  paymentStatus PaymentStatus @default(PENDING) @map("payment_status")
  paidAt        DateTime? @map("paid_at")
  
  // Relaciones
  items         OrderItem[]
  trackingHistory OrderTracking[]
  
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  quantity  Int
  price     Decimal @db.Decimal(10, 2)
  size      String
  color     String
  
  orderId   String @map("order_id")
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId String @map("product_id")
  product   Product @relation(fields: [productId], references: [id])
  
  @@map("order_items")
}

// Historial de tracking de cada orden
model OrderTracking {
  id          String    @id @default(cuid())
  status      OrderStatus
  description String?
  location    String?
  
  orderId     String @map("order_id")
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  createdBy   String? @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  
  @@map("order_tracking")
  @@index([orderId])
}

enum OrderStatus {
  PENDING       // Pendiente de pago
  PAID          // Pagado, esperando preparación
  PROCESSING    // Preparando pedido
  READY         // Listo para envío
  SHIPPED       // Enviado
  IN_TRANSIT    // En tránsito
  OUT_FOR_DELIVERY // En reparto
  DELIVERED     // Entregado
  CANCELLED     // Cancelado
  REFUNDED      // Reembolsado
}

enum PaymentStatus {
  PENDING
  PROCESSING
  APPROVED
  DECLINED
  ERROR
  REFUNDED
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  lastLogin DateTime? @map("last_login")
  createdAt DateTime @default(now()) @map("created_at")
  
  @@map("admins")
}
